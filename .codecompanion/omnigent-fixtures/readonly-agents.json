        {
            "id": "ag_057995d1517418e6839f51d340785dd6",
            "object": "agent",
            "name": "polly",
            "version": 1,
            "description": "A coding orchestrator that breaks your goal into pieces and hands them to a team of Claude Code, Codex, OpenCode, Cursor, Hermes, and Pi sub-agents to build. Polly writes no code itself \u2014 it plans and splits up the work, delegates all of it (investigation / implementation / review), then has a separate independent different-model reviewer double-check the work before putting it all together. Best for bigger tasks you want planned and split up.",
            "created_at": 1784064087,
            "updated_at": null,
            "harness": "claude-sdk",
            "mcp_servers": [],
            "mcp_servers_editable": false,
            "policies": [],
            "skills": [
                {
                    "name": "cross-review",
                    "description": "Verify an implementer's diff with an INDEPENDENT, different-vendor sub-agent (diff plus contract only); turn blocking issues into fix-tasks and loop until clean."
                },
                {
                    "name": "fanout",
                    "description": "Run independent subtasks in parallel \u2014 one git worktree and one implementation sub-agent per task, each opening its own PR \u2014 then cross-review every PR. polly never merges; the human does."
                },
                {
                    "name": "investigate",
                    "description": "Delegate read-only investigation, debugging, audit, search, or code-understanding tasks to sub-agents; synthesize only from their structured reports."
                }
            ],
            "terminals": [
                "shell",
                "zsh"
            ],
            "builtin": true
        }
